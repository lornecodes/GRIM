# GRIM Environment Configuration
# Copy to .env and fill in your values

# LLM Provider
# Option 1: Direct API key (bypasses CLIProxyAPI)
# ANTHROPIC_API_KEY=sk-ant-api03-...
#
# Option 2: CLIProxyAPI proxy (uses Claude Max subscription via OAuth)
# The proxy handles auth — this placeholder satisfies the SDK requirement.
# Run `docker exec -it cliproxyapi /CLIProxyAPI/CLIProxyAPI --claude-login`
# once to authenticate, then tokens persist in the cliproxyapi-auths volume.
ANTHROPIC_API_KEY=sk-placeholder-for-proxy

# Obsidian Local REST API (from Obsidian plugin settings)
OBSIDIAN_API_KEY=your_obsidian_api_key_here
OBSIDIAN_HOST=127.0.0.1
OBSIDIAN_PORT=27124

# Telegram (optional - enable in config/grim.yaml)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Proton Drive backup (optional)
# RCLONE_REMOTE=proton:grim-vault
