# GRIM Environment Configuration
# Copy to .env and fill in your values

# LLM Provider
ANTHROPIC_API_KEY=sk-ant-api03-...

# Obsidian Local REST API (from Obsidian plugin settings)
OBSIDIAN_API_KEY=your_obsidian_api_key_here
OBSIDIAN_HOST=127.0.0.1
OBSIDIAN_PORT=27124

# Telegram (optional - enable in config/grim.yaml)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Proton Drive backup (optional)
# RCLONE_REMOTE=proton:grim-vault
