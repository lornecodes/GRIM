# ── GRIM Docker build context exclusions ──────────────────
# Keep the build context small and the image clean.

# Version control
.git/
.gitignore

# Test cache (tests themselves are included for in-container validation)
.pytest_cache/

# Local state / secrets
.env
*.db
local/
output/
tmp/

# Python cache
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Docker (don't recurse)
Dockerfile
docker-compose*.yml
.dockerignore

# Docs / changelogs (not needed at runtime)
.changelog/
/README.md
CHANGELOG.md

# Dev tools
tools/
scripts/

# Obsidian MCP (optional, not needed in core image)
mcp/obsidian/
